<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- 1. Maintain a list of active browser "sessions" listening for updates -->
    <service verb="register" noun="Client" transaction="ignore" require-authentication="false">
        <out-parameters>
            <parameter name="timestamp" type="String"/>
        </out-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/WebMcpServices_registerClient.groovy"/>
        </actions>
    </service>
    
    <!-- Generate a secure UUID handshake token for the current session -->
    <service verb="get" noun="ConnectionToken" require-authentication="false">
        <out-parameters>
            <parameter name="connectionToken" type="String" required="true"/>
        </out-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/WebMcpServices_getConnectionToken.groovy"/>
        </actions>
    </service>

    <!-- The 'Front Door' for the AI to push architect actions -->
    <service verb="post" noun="Command" require-authentication="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
            <parameter name="action" required="true"/>
            <parameter name="payload" type="Map"/>
        </in-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/WebMcpServices_postCommand.groovy"/>
        </actions>
    </service>

    <!-- 2. Broadcast a lightweight JSON ping to listening browsers -->
    <service verb="push" noun="BlueprintUpdate" require-authentication="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
            <parameter name="screenPath" required="true"/>
        </in-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/WebMcpServices_pushBlueprintUpdate.groovy"/>
        </actions>
    </service>

    <!-- 3. Returns a "Knowledge Bundle" for the AI (Macros, HIPAA, Entities) -->
    <service verb="get" noun="Context" require-authentication="false">
        <in-parameters>
            <parameter name="componentName" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="macros" type="Map"/>
            <parameter name="hipaaRules" type="Map"/>
            <parameter name="entityMetadata" type="Map"/>
        </out-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/WebMcpServices_getContext.groovy"/>
        </actions>
    </service>

    <service verb="post" noun="Prompt" require-authentication="false">
        <in-parameters>
            <parameter name="prompt" type="String" required="true"/>
            <parameter name="componentName" type="String"/>
            <parameter name="screenPath" type="String"/>
            <parameter name="selectedId" type="String"/>
            <parameter name="selectedProps" type="Map"/>
        </in-parameters>
        <out-parameters>
            <parameter name="aiResponse" type="String" required="true"/>
        </out-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/WebMcpServices_postPrompt.groovy"/>
        </actions>
    </service>

    <!-- NEW PROJECT SERVICES CONSOLIDATED -->
    <service verb="get" noun="Components" require-authentication="false">
        <out-parameters>
            <parameter name="components" type="List"/>
        </out-parameters>
        <actions>
            <script><![CDATA[
                def runtimePath = ec.factory.runtimePath
                def componentDir = new File(runtimePath, "component")
                def list = []
                if (componentDir.exists()) {
                    componentDir.listFiles().each { 
                        if (it.isDirectory() && !it.name.startsWith(".")) {
                            list.add(it.name)
                        }
                    }
                }
                context.components = list.sort()
            ]]></script>
        </actions>
    </service>

    <service verb="post" noun="Component" require-authentication="false">
        <in-parameters>
            <parameter name="componentName" type="String" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="success" type="Boolean"/>
            <parameter name="message" type="String"/>
        </out-parameters>
        <actions>
            <script location="component://moqui-ai/service/moquiai/ProjectServices_createComponent.groovy"/>
        </actions>
    </service>

</services>
