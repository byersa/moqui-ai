{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aitree Blueprint Schema",
  "type": "object",
  "required": ["meta", "structure"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "intent": { "type": "string" },
        "hipaa_audit": { "type": "boolean", "default": true }
      }
    },
    "structure": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    },
    "context": { "type": "object" }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["component"],
      "properties": {
        "id": { "type": "string" },
        "component": { "type": "string" },
        "properties": { "type": "object" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/component" } }
      }
    }
  }
}
