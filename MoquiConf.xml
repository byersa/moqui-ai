<?xml version="1.0" encoding="UTF-8"?>
<moqui-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-3.xsd">


    <resource-facade>
        <template-location location="component://webroot/template/screen/routes.js.ftl" 
                          override-location="component://moqui-ai/template/screen/routes.js.ftl"/>
    </resource-facade>

    <webapp-list>
    </webapp-list>

    <screen-facade>
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="moquiai" menu-title="MoquiAi" menu-index="96"
                             menu-include="false"
                             location="component://moqui-ai/screen/moquiai.xml"/>
        </screen>
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="moqui-ai" menu-title="Moqui-ai" menu-index="97"
                             menu-include="false"
                             location="component://moqui-ai/screen/moqui-ai.xml"/>
        </screen>

        <!-- Use the DeterministicVueRenderer for qjson instead of the default macro-based one -->
        <screen-output type="qjson" mime-type="application/json" always-standalone="false"
                       widget-render-class="org.moqui.ai.impl.screen.DeterministicVueRenderer"/>

        <!-- Overriding the default HTML macros to support MoquiAi semantic tags in the shell and beyond -->
        <screen-text-output type="html" mime-type="text/html"
                            macro-template-location="component://moqui-ai/template/MoquiAiShellMacros.html.ftl"/>

        <screen-text-output type="qvt" mime-type="text/html" always-standalone="false"
                            macro-template-location="component://moqui-ai/template/MoquiAiScreenMacros.qvt.ftl"/>

    </screen-facade>
</moqui-conf>
